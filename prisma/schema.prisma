  changedByUser   User?              @relation(fields: [changedByUserId], references: [id], onDelete: SetNull)

  @@index([leaseId])
  @@index([orgId, leaseId, createdAt])
}

model LeaseActivity {
  id              String              @id @default(uuid())
  orgId           String
  leaseId         String
  action          LeaseActivityAction
  source          LeaseActivitySource @default(USER)
  changedByUserId String?

}

model LeaseParkingSticker {
  id            String           @id @default(uuid())
  leaseId       String
  stickerNumber String
  status        AccessItemStatus @default(ISSUED)
  issuedAt      DateTime         @default(now())
  returnedAt    DateTime?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  lease         Lease            @relation(fields: [leaseId], references: [id], onDelete: Cascade)

  @@unique([leaseId, stickerNumber])
  @@index([leaseId])
  @@index([leaseId, status])
}

model LeaseOccupant {
  id        String   @id @default(uuid())
  leaseId   String
  name      String
  createdAt DateTime @default(now())
  lease     Lease    @relation(fields: [leaseId], references: [id], onDelete: Cascade)

  @@index([leaseId])
}

model LeaseAdditionalTerm {
  id        String   @id @default(uuid())
  leaseId   String
  orgId     String
  termText  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  lease     Lease    @relation(fields: [leaseId], references: [id], onDelete: Cascade)
  org       Org      @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([leaseId])
  @@index([orgId, leaseId])
}

model MoveInRequest {
  id               String            @id @default(uuid())
  orgId            String
  buildingId       String
  unitId           String
  leaseId          String
  residentUserId   String
  status           MoveRequestStatus @default(PENDING)
  requestedMoveAt  DateTime
  notes            String?
  reviewedByUserId String?
  reviewedAt       DateTime?
  rejectionReason  String?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  org              Org               @relation(fields: [orgId], references: [id], onDelete: Cascade)
  building         Building          @relation(fields: [buildingId], references: [id], onDelete: Cascade)
  unit             Unit              @relation(fields: [unitId], references: [id], onDelete: Cascade)
  lease            Lease             @relation(fields: [leaseId], references: [id], onDelete: Cascade)
  residentUser     User              @relation("MoveInRequestResident", fields: [residentUserId], references: [id], onDelete: Cascade)
  reviewedByUser   User?             @relation("MoveInRequestReviewer", fields: [reviewedByUserId], references: [id], onDelete: SetNull)

  @@index([orgId, buildingId, status])

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                                         String                                 @id @default(uuid())
  email                                      String                                 @unique
  passwordHash                               String
  refreshTokenHash                           String?
  name                                       String?
  avatarUrl                                  String?
  phone                                      String?
  orgId                                      String?
  mustChangePassword                         Boolean                                @default(false)
  isActive                                   Boolean                                @default(true)
  createdAt                                  DateTime                               @default(now())
  updatedAt                                  DateTime                               @updatedAt
  org                                        Org?                                   @relation(fields: [orgId], references: [id], onDelete: Cascade)
  accessAssignments                          UserAccessAssignment[]
  userPermissions                            UserPermission[]
  residentOccupancies                        Occupancy[]
  maintenanceRequestsCreated                 MaintenanceRequest[]                   @relation("MaintenanceRequestCreator")
  maintenanceRequestsAssigned                MaintenanceRequest[]                   @relation("MaintenanceRequestAssignee")
  maintenanceRequestsServiceProviderAssigned MaintenanceRequest[]                   @relation("MaintenanceRequestServiceProviderAssignee")
  maintenanceRequestsEstimateRequested       MaintenanceRequest[]                   @relation("MaintenanceRequestEstimateRequester")
  maintenanceRequestsEstimateSubmitted       MaintenanceRequest[]                   @relation("MaintenanceRequestEstimateSubmitter")
  maintenanceRequestsOwnerApprovalRequested  MaintenanceRequest[]                   @relation("MaintenanceRequestOwnerApprovalRequester")
  maintenanceRequestsOwnerApprovalDecided    MaintenanceRequest[]                   @relation("MaintenanceRequestOwnerApprovalDecider")
  maintenanceRequestsOwnerApprovalOverridden MaintenanceRequest[]                   @relation("MaintenanceRequestOwnerApprovalOverrider")
  maintenanceRequestComments                 MaintenanceRequestComment[]
  maintenanceRequestCommentReadStates        MaintenanceRequestCommentReadState[]
  maintenanceRequestAttachments              MaintenanceRequestAttachment[]
  maintenanceRequestOwnerApprovalAudits      MaintenanceRequestOwnerApprovalAudit[] @relation("MaintenanceRequestOwnerApprovalAuditActor")
  notifications                              Notification[]                         @relation("NotificationRecipient")
  broadcastsSent                             Broadcast[]                            @relation("BroadcastSender")
  conversationParticipations                 ConversationParticipant[]
  messagesSent                               Message[]                              @relation("MessageSender")
  residentProfile                            ResidentProfile?
  primaryContracts                           Lease[]                                @relation("LeasePrimaryResident")
  moveInRequests                             MoveInRequest[]                        @relation("MoveInRequestResident")
  moveOutRequests                            MoveOutRequest[]                       @relation("MoveOutRequestResident")
  reviewedMoveInRequests                     MoveInRequest[]                        @relation("MoveInRequestReviewer")
  reviewedMoveOutRequests                    MoveOutRequest[]                       @relation("MoveOutRequestReviewer")
  leaseHistoryChanges                        LeaseHistory[]
  leaseActivityChanges                       LeaseActivity[]
  passwordResetTokens                        PasswordResetToken[]
  residentInvitesReceived                    ResidentInvite[]                       @relation("ResidentInviteRecipient")
  residentInvitesCreated                     ResidentInvite[]                       @relation("ResidentInviteCreator")
  pushDevices                                PushDevice[]
  serviceProviderMemberships                 ServiceProviderUser[]
  serviceProviderAccessGrants                ServiceProviderAccessGrant[]           @relation("ServiceProviderAccessGrantUser")
  grantedServiceProviderAccessGrants         ServiceProviderAccessGrant[]           @relation("ServiceProviderAccessGrantGrantedBy")
  disabledServiceProviderAccessGrants        ServiceProviderAccessGrant[]           @relation("ServiceProviderAccessGrantDisabledBy")
  ownerAccessGrants                          OwnerAccessGrant[]                     @relation("OwnerAccessGrantUser")
  grantedOwnerAccessGrants                   OwnerAccessGrant[]                     @relation("OwnerAccessGrantGrantedBy")
  disabledOwnerAccessGrants                  OwnerAccessGrant[]                     @relation("OwnerAccessGrantDisabledBy")
  ownerAccessGrantAuditActions               OwnerAccessGrantAudit[]                @relation("OwnerAccessGrantAuditActor")
  ownerRegistryLookupAudits                  OwnerRegistryLookupAudit[]             @relation("OwnerRegistryLookupAuditActor")
  ownerRequestCommentReadStates              OwnerRequestCommentReadState[]

  @@index([orgId])
}

model PasswordResetToken {
  id        String    @id @default(uuid())
  userId    String
  tokenHash String    @unique
  purpose   String    @default("PASSWORD_RESET")
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
  @@index([userId, purpose, expiresAt])
  @@index([expiresAt])
}

enum DeliveryTaskKind {
  AUTH_PASSWORD_EMAIL
  PUSH_NOTIFICATION
  BROADCAST_FANOUT
}

enum DeliveryTaskStatus {
  PENDING
  PROCESSING
  SUCCEEDED
  FAILED
  RETRIED
}

model DeliveryTask {
  id                  String                @id @default(uuid())
  kind                DeliveryTaskKind
  status              DeliveryTaskStatus    @default(PENDING)
  queueName           String
  jobName             String
  orgId               String?
  userId              String?
  referenceType       String?
  referenceId         String?
  payload             Json
  attemptCount        Int                   @default(0)
  maxAttempts         Int                   @default(5)
  queuedAt            DateTime              @default(now())
  lastAttemptAt       DateTime?
  processingStartedAt DateTime?
  completedAt         DateTime?
  lastError           String?
  retriedAt           DateTime?
  replacedByTaskId    String?
  createdAt           DateTime              @default(now())
  updatedAt           DateTime              @updatedAt
  pushReceipts        PushDeliveryReceipt[]

  @@index([status, kind, queuedAt])
  @@index([referenceType, referenceId])
  @@index([orgId, kind, createdAt])
  @@index([userId, kind, createdAt])
  @@index([replacedByTaskId])
}

enum ResidentInviteStatus {
  SENT
  FAILED
  ACCEPTED
}

model ResidentInvite {
  id              String               @id @default(uuid())
  orgId           String
  userId          String
  createdByUserId String?
  email           String
  status          ResidentInviteStatus @default(SENT)
  tokenHash       String               @unique
  expiresAt       DateTime
  sentAt          DateTime             @default(now())
  acceptedAt      DateTime?
  failedAt        DateTime?
  failureReason   String?
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
  org             Org                  @relation(fields: [orgId], references: [id], onDelete: Cascade)
  user            User                 @relation("ResidentInviteRecipient", fields: [userId], references: [id], onDelete: Cascade)
  createdByUser   User?                @relation("ResidentInviteCreator", fields: [createdByUserId], references: [id], onDelete: SetNull)

  @@index([orgId, createdAt])
  @@index([userId, createdAt])
  @@index([orgId, userId, createdAt])
  @@index([status, expiresAt])
}

model Org {
  id                                    String                                 @id @default(uuid())
  name                                  String
  logoUrl                               String?
  businessName                          String?
  businessType                          OrgBusinessType?
  tradeLicenseNumber                    String?
  vatRegistrationNumber                 String?
  registeredOfficeAddress               String?
  city                                  String?
  officePhoneNumber                     String?
  businessEmailAddress                  String?
  website                               String?
  ownerName                             String?
  createdAt                             DateTime                               @default(now())
  updatedAt                             DateTime                               @updatedAt
  users                                 User[]
  buildings                             Building[]
  unitTypes                             UnitType[]
  owners                                Owner[]
  maintenanceRequests                   MaintenanceRequest[]
  maintenanceRequestComments            MaintenanceRequestComment[]
  maintenanceRequestAttachments         MaintenanceRequestAttachment[]
  maintenanceRequestOwnerApprovalAudits MaintenanceRequestOwnerApprovalAudit[]
  notifications                         Notification[]
  broadcasts                            Broadcast[]
  conversations                         Conversation[]
  roleTemplates                         RoleTemplate[]
  parkingSlots                          ParkingSlot[]
  parkingAllocations                    ParkingAllocation[]
  vehicles                              Vehicle[]
  visitors                              Visitor[]
  leases                                Lease[]
  residentProfiles                      ResidentProfile[]
  leaseDocuments                        LeaseDocument[]
  leaseHistories                        LeaseHistory[]
  leaseActivities                       LeaseActivity[]
  leaseAdditionalTerms                  LeaseAdditionalTerm[]
  moveInRequests                        MoveInRequest[]
  moveOutRequests                       MoveOutRequest[]
  residentInvites                       ResidentInvite[]
  pushDevices                           PushDevice[]
  unitOwnerships                        UnitOwnership[]
  ownerRegistryLookupAudits             OwnerRegistryLookupAudit[]
}

enum PartyType {
  INDIVIDUAL
  COMPANY
}

enum PartyStatus {
  ACTIVE
  ARCHIVED
}

enum PartyIdentifierType {
  EMIRATES_ID
  PASSPORT
  TRADE_LICENSE
  VAT_TRN
  OTHER
}

enum OwnerAccessGrantStatus {
  PENDING
  ACTIVE
  DISABLED
}

enum OwnerAccessGrantAuditAction {
  INVITED
  LINKED
  ACTIVATED
  DISABLED
  RESENT
}

enum ServiceProviderUserRole {
  ADMIN
  WORKER
}

enum ServiceProviderAccessGrantStatus {
  PENDING
  ACTIVE
  DISABLED
}

enum OwnerRegistryLookupResultStatus {
  MATCH_FOUND
  NO_MATCH
}

enum PushProvider {
  EXPO
}

enum PushPlatform {
  IOS
  ANDROID
  WEB
  UNKNOWN
}

enum PushDeliveryReceiptStatus {
  PENDING
  DELIVERED
  ERROR
}

model PushDevice {
  id         String       @id @default(uuid())
  orgId      String?
  userId     String
  provider   PushProvider
  platform   PushPlatform @default(UNKNOWN)
  token      String       @unique
  deviceId   String?
  appId      String?
  isActive   Boolean      @default(true)
  lastSeenAt DateTime     @default(now())
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt
  org        Org?         @relation(fields: [orgId], references: [id], onDelete: Cascade)
  user       User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([orgId, userId, isActive])
  @@index([userId, isActive])
  @@index([lastSeenAt])
}

model PushDeliveryReceipt {
  id                String                    @id @default(uuid())
  taskId            String
  provider          PushProvider
  platform          PushPlatform              @default(UNKNOWN)
  userId            String?
  pushDeviceId      String?
  deviceTokenMasked String?
  providerTicketId  String?                   @unique
  providerReceiptId String?
  status            PushDeliveryReceiptStatus @default(PENDING)
  errorCode         String?
  errorMessage      String?
  details           Json?
  checkedAt         DateTime?
  createdAt         DateTime                  @default(now())
  updatedAt         DateTime                  @updatedAt
  task              DeliveryTask              @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId, status, createdAt])
  @@index([provider, status, checkedAt])
}

enum OrgBusinessType {
  OWNER
  PROPERTY_MANAGEMENT
  FACILITY_MANAGEMENT
  DEVELOPER
}

model Building {
  id                   String                    @id @default(uuid())
  orgId                String
  name                 String
  city                 String
  emirate              String?
  country              String                    @default("ARE")
  timezone             String                    @default("Asia/Dubai")
  floors               Int?
  unitsCount           Int?
  createdAt            DateTime                  @default(now())
  updatedAt            DateTime                  @updatedAt
  org                  Org                       @relation(fields: [orgId], references: [id], onDelete: Cascade)
  units                Unit[]
  amenities            BuildingAmenity[]
  accessAssignments    UserAccessAssignment[]    @relation("BuildingScopedAccessAssignments")
  occupancies          Occupancy[]
  maintenanceRequests  MaintenanceRequest[]
  parkingSlots         ParkingSlot[]
  parkingAllocations   ParkingAllocation[]
  visitors             Visitor[]
  conversations        Conversation[]
  leases               Lease[]
  moveInRequests       MoveInRequest[]
  moveOutRequests      MoveOutRequest[]
  residentProfiles     ResidentProfile[]
  serviceProviderLinks ServiceProviderBuilding[]

  @@index([orgId])
}

model Unit {
  id                     String               @id @default(uuid())
  buildingId             String
  label                  String
  unitTypeId             String?
  ownerId                String?
  floor                  Int?
  status                 UnitStatus           @default(AVAILABLE)
  notes                  String?
  maintenancePayer       MaintenancePayer?
  unitSize               Decimal?             @db.Decimal(12, 2)
  unitSizeUnit           UnitSizeUnit         @default(SQ_FT)
  bedrooms               Int?
  bathrooms              Int?
  balcony                Boolean?
  kitchenType            KitchenType?
  furnishedStatus        FurnishedStatus?
  rentAnnual             Decimal?             @db.Decimal(12, 2)
  paymentFrequency       PaymentFrequency?
  securityDepositAmount  Decimal?             @db.Decimal(12, 2)
  serviceChargePerUnit   Decimal?             @db.Decimal(12, 2)
  vatApplicable          Boolean?
  electricityMeterNumber String?
  waterMeterNumber       String?
  gasMeterNumber         String?
  createdAt              DateTime             @default(now())
  updatedAt              DateTime             @updatedAt
  building               Building             @relation(fields: [buildingId], references: [id], onDelete: Cascade)
  unitType               UnitType?            @relation(fields: [unitTypeId], references: [id], onDelete: SetNull)
  owner                  Owner?               @relation(fields: [ownerId], references: [id], onDelete: SetNull)
  amenities              UnitAmenity[]
  ownerships             UnitOwnership[]
  occupancies            Occupancy[]
  leases                 Lease[]
  moveInRequests         MoveInRequest[]
  moveOutRequests        MoveOutRequest[]
  parkingAllocations     ParkingAllocation[]
  maintenanceRequests    MaintenanceRequest[]
  visitors               Visitor[]

  @@unique([buildingId, label])
  @@index([buildingId])
}

model Visitor {
  id                String        @id @default(uuid())
  orgId             String
  buildingId        String
  unitId            String
  type              VisitorType
  status            VisitorStatus @default(EXPECTED)
  visitorName       String
  phoneNumber       String
  emiratesId        String?
  vehicleNumber     String?
  expectedArrivalAt DateTime?
  notes             String?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  org               Org           @relation(fields: [orgId], references: [id], onDelete: Cascade)
  building          Building      @relation(fields: [buildingId], references: [id], onDelete: Cascade)
  unit              Unit          @relation(fields: [unitId], references: [id], onDelete: Cascade)

  @@index([orgId, buildingId])
  @@index([orgId, createdAt])
  @@index([unitId])
}

model BuildingAmenity {
  id         String        @id @default(uuid())
  buildingId String
  name       String
  isActive   Boolean       @default(true)
  isDefault  Boolean       @default(false)
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt
  building   Building      @relation(fields: [buildingId], references: [id], onDelete: Cascade)
  unitLinks  UnitAmenity[]

  @@unique([buildingId, name])
  @@index([buildingId])
}

model UnitAmenity {
  unitId    String
  amenityId String
  createdAt DateTime        @default(now())
  unit      Unit            @relation(fields: [unitId], references: [id], onDelete: Cascade)
  amenity   BuildingAmenity @relation(fields: [amenityId], references: [id], onDelete: Cascade)

  @@id([unitId, amenityId])
  @@index([amenityId])
}

model UnitType {
  id        String   @id @default(uuid())
  orgId     String
  name      String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  org       Org      @relation(fields: [orgId], references: [id], onDelete: Cascade)
  units     Unit[]

  @@unique([orgId, name])
  @@index([orgId])
}

model Owner {
  id                         String                      @id @default(uuid())
  orgId                      String
  partyId                    String?
  name                       String
  email                      String?
  phone                      String?
  address                    String?
  isActive                   Boolean                     @default(true)
  displayNameOverride        String?
  contactEmailOverride       String?
  contactPhoneOverride       String?
  notes                      String?
  createdAt                  DateTime                    @default(now())
  updatedAt                  DateTime                    @updatedAt
  org                        Org                         @relation(fields: [orgId], references: [id], onDelete: Cascade)
  party                      Party?                      @relation(fields: [partyId], references: [id], onDelete: SetNull)
  units                      Unit[]
  accessGrants               OwnerAccessGrant[]
  accessGrantAudits          OwnerAccessGrantAudit[]
  unitOwnerships             UnitOwnership[]
  maintenanceRequestComments MaintenanceRequestComment[] @relation("MaintenanceRequestCommentOwner")

  @@unique([orgId, partyId])
  @@index([orgId])
  @@index([partyId])
  @@index([orgId, isActive])
}

model Party {
  id                  String                     @id @default(uuid())
  type                PartyType
  displayNameEn       String
  displayNameAr       String?
  primaryEmail        String?
  primaryPhone        String?
  status              PartyStatus                @default(ACTIVE)
  createdAt           DateTime                   @default(now())
  updatedAt           DateTime                   @updatedAt
  identifiers         PartyIdentifier[]
  owners              Owner[]
  matchedLookupAudits OwnerRegistryLookupAudit[]

  @@index([type])
  @@index([displayNameEn])
  @@index([primaryEmail])
}

model PartyIdentifier {
  id                   String              @id @default(uuid())
  partyId              String
  identifierType       PartyIdentifierType
  countryCode          String?
  issuingAuthority     String?
  valueEncrypted       String
  lookupHmac           String
  last4                String?
  isPrimary            Boolean             @default(false)
  isVerified           Boolean             @default(false)
  normalizationVersion Int                 @default(1)
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt
  deletedAt            DateTime?
  party                Party               @relation(fields: [partyId], references: [id], onDelete: Cascade)

  @@index([partyId, identifierType])
  @@index([identifierType, countryCode, issuingAuthority, lookupHmac])
}

model OwnerAccessGrant {
  id                 String                  @id @default(uuid())
  userId             String?
  ownerId            String
  status             OwnerAccessGrantStatus  @default(PENDING)
  inviteEmail        String?
  invitedAt          DateTime?
  acceptedAt         DateTime?
  grantedByUserId    String?
  disabledAt         DateTime?
  disabledByUserId   String?
  verificationMethod String?
  createdAt          DateTime                @default(now())
  updatedAt          DateTime                @updatedAt
  user               User?                   @relation("OwnerAccessGrantUser", fields: [userId], references: [id], onDelete: Cascade)
  owner              Owner                   @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  grantedByUser      User?                   @relation("OwnerAccessGrantGrantedBy", fields: [grantedByUserId], references: [id], onDelete: SetNull)
  disabledByUser     User?                   @relation("OwnerAccessGrantDisabledBy", fields: [disabledByUserId], references: [id], onDelete: SetNull)
  audits             OwnerAccessGrantAudit[]

  @@index([userId, status])
  @@index([ownerId, status])
  @@index([createdAt])
}

model OwnerAccessGrantAudit {
  id                 String                      @id @default(uuid())
  grantId            String
  ownerId            String
  actorUserId        String?
  action             OwnerAccessGrantAuditAction
  fromStatus         OwnerAccessGrantStatus?
  toStatus           OwnerAccessGrantStatus
  userId             String?
  inviteEmail        String?
  verificationMethod String?
  createdAt          DateTime                    @default(now())
  grant              OwnerAccessGrant            @relation(fields: [grantId], references: [id], onDelete: Cascade)
  owner              Owner                       @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  actorUser          User?                       @relation("OwnerAccessGrantAuditActor", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([ownerId, createdAt])
  @@index([grantId, createdAt])
  @@index([actorUserId])
}

model ServiceProvider {
  id                  String                       @id @default(uuid())
  name                String
  serviceCategory     String?
  contactName         String?
  contactEmail        String?
  contactPhone        String?
  notes               String?
  isActive            Boolean                      @default(true)
  createdAt           DateTime                     @default(now())
  updatedAt           DateTime                     @updatedAt
  buildings           ServiceProviderBuilding[]
  users               ServiceProviderUser[]
  accessGrants        ServiceProviderAccessGrant[]
  maintenanceRequests MaintenanceRequest[]

  @@index([isActive])
  @@index([name])
}

model ServiceProviderBuilding {
  serviceProviderId String
  buildingId        String
  createdAt         DateTime        @default(now())
  serviceProvider   ServiceProvider @relation(fields: [serviceProviderId], references: [id], onDelete: Cascade)
  building          Building        @relation(fields: [buildingId], references: [id], onDelete: Cascade)

  @@id([serviceProviderId, buildingId])
  @@index([buildingId])
}

model ServiceProviderUser {
  serviceProviderId String
  userId            String
  role              ServiceProviderUserRole @default(WORKER)
  isActive          Boolean                 @default(true)
  createdAt         DateTime                @default(now())
  updatedAt         DateTime                @updatedAt
  serviceProvider   ServiceProvider         @relation(fields: [serviceProviderId], references: [id], onDelete: Cascade)
  user              User                    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([serviceProviderId, userId])
  @@index([userId, isActive])
  @@index([serviceProviderId, role, isActive])
}

model ServiceProviderAccessGrant {
  id                 String                           @id @default(uuid())
  userId             String?
  serviceProviderId  String
  status             ServiceProviderAccessGrantStatus @default(PENDING)
  inviteEmail        String?
  invitedAt          DateTime?
  acceptedAt         DateTime?
  grantedByUserId    String?
  disabledAt         DateTime?
  disabledByUserId   String?
  verificationMethod String?
  createdAt          DateTime                         @default(now())
  updatedAt          DateTime                         @updatedAt
  user               User?                            @relation("ServiceProviderAccessGrantUser", fields: [userId], references: [id], onDelete: Cascade)
  serviceProvider    ServiceProvider                  @relation(fields: [serviceProviderId], references: [id], onDelete: Cascade)
  grantedByUser      User?                            @relation("ServiceProviderAccessGrantGrantedBy", fields: [grantedByUserId], references: [id], onDelete: SetNull)
  disabledByUser     User?                            @relation("ServiceProviderAccessGrantDisabledBy", fields: [disabledByUserId], references: [id], onDelete: SetNull)

  @@index([userId, status])
  @@index([serviceProviderId, status])
  @@index([createdAt])
}

model OwnerRegistryLookupAudit {
  id             String                          @id @default(uuid())
  actorUserId    String
  actorOrgId     String
  identifierType PartyIdentifierType
  lookupHmac     String
  resultStatus   OwnerRegistryLookupResultStatus
  matchedPartyId String?
  createdAt      DateTime                        @default(now())
  actorUser      User                            @relation("OwnerRegistryLookupAuditActor", fields: [actorUserId], references: [id], onDelete: Cascade)
  actorOrg       Org                             @relation(fields: [actorOrgId], references: [id], onDelete: Cascade)
  matchedParty   Party?                          @relation(fields: [matchedPartyId], references: [id], onDelete: SetNull)

  @@index([actorUserId, createdAt])
  @@index([actorOrgId, createdAt])
  @@index([identifierType, createdAt])
}

model UnitOwnership {
  id        String    @id @default(uuid())
  orgId     String
  unitId    String
  ownerId   String
  startDate DateTime
  endDate   DateTime?
  isPrimary Boolean?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  org       Org       @relation(fields: [orgId], references: [id], onDelete: Cascade)
  unit      Unit      @relation(fields: [unitId], references: [id], onDelete: Cascade)
  owner     Owner     @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  @@index([orgId, ownerId, startDate, endDate])
  @@index([orgId, unitId, startDate, endDate])
  @@index([unitId, endDate])
}

enum MaintenancePayer {
  OWNER
  TENANT
  BUILDING
}

enum VisitorType {
  GUEST_VISITOR
  DELIVERY_RIDER
  COURIER_PARCEL
  SERVICE_PROVIDER
  MAINTENANCE_TECHNICIAN
  HOUSEKEEPING_CLEANER
  CONTRACTOR_WORKER
  DRIVER_PICKUP
  SECURITY_STAFF_EXTERNAL
  OTHER
}

enum VisitorStatus {
  EXPECTED
  ARRIVED
  COMPLETED
  CANCELLED
}

enum KitchenType {
  OPEN
  CLOSED
}

enum FurnishedStatus {
  UNFURNISHED
  SEMI_FURNISHED
  FULLY_FURNISHED
}

enum PaymentFrequency {
  MONTHLY
  QUARTERLY
  SEMI_ANNUAL
  ANNUAL
}

enum LeaseStatus {
  DRAFT
  ACTIVE
  ENDED
  CANCELLED
}

enum PropertyUsage {
  INDUSTRIAL
  COMMERCIAL
  RESIDENTIAL
}

enum LeaseHistoryAction {
  CREATED
  UPDATED
  MOVED_OUT
}

enum LeaseActivityAction {
  MOVE_IN
  MOVE_OUT
  MOVE_IN_REQUEST_CREATED
  MOVE_IN_REQUEST_APPROVED
  MOVE_IN_REQUEST_REJECTED
  MOVE_OUT_REQUEST_CREATED
  MOVE_OUT_REQUEST_APPROVED
  MOVE_OUT_REQUEST_REJECTED
  CONTRACT_ACTIVATED
  CONTRACT_CANCELLED
  DOCUMENT_ADDED
  DOCUMENT_DELETED
  ACCESS_CARD_ISSUED
  ACCESS_CARD_STATUS_CHANGED
  ACCESS_CARD_DELETED
  PARKING_STICKER_ISSUED
  PARKING_STICKER_STATUS_CHANGED
  PARKING_STICKER_DELETED
  OCCUPANTS_REPLACED
  PARKING_ALLOCATED
  PARKING_ALLOCATION_ENDED
  VEHICLE_ADDED
  VEHICLE_UPDATED
  VEHICLE_DELETED
}

enum LeaseActivitySource {
  USER
  SYSTEM
}

enum UnitStatus {
  AVAILABLE
  OCCUPIED
  UNDER_MAINTENANCE
  BLOCKED
}

enum ServiceChargesPaidBy {
  OWNER
  TENANT
}

enum YesNo {
  YES
  NO
}

enum ConditionStatus {
  OK
  REPAIR_NEEDED
}

enum ApprovalStatus {
  APPROVED
  PENDING
  REJECTED
}

enum RefundMethod {
  BANK_TRANSFER
  CHEQUE
  CASH
}

enum LeaseDocumentType {
  EMIRATES_ID_COPY
  PASSPORT_COPY
  SIGNED_TENANCY_CONTRACT
  CHEQUE_COPY
  OTHER
}

enum AccessItemStatus {
  ISSUED
  RETURNED
  DEACTIVATED
}

enum MoveRequestStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
  COMPLETED
}

enum UnitSizeUnit {
  SQ_FT
}

enum ParkingSlotType {
  CAR
  BIKE
  EV
}

enum AccessScopeType {
  ORG
  BUILDING
}

enum OccupancyStatus {
  ACTIVE
  ENDED
}

model Occupancy {

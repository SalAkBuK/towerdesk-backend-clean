  lease           Lease               @relation(fields: [leaseId], references: [id], onDelete: Cascade)
  changedByUser   User?               @relation(fields: [changedByUserId], references: [id], onDelete: SetNull)

  @@index([leaseId])
  @@index([orgId, leaseId, createdAt])
}

model ResidentProfile {

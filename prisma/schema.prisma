  reviewedByUser   User?             @relation("MoveOutRequestReviewer", fields: [reviewedByUserId], references: [id], onDelete: SetNull)

  @@index([orgId, buildingId, status])
  @@index([leaseId, status])
  @@index([residentUserId, status])
}

model ParkingSlot {
  id          String              @id @default(cuid())
  orgId       String
  buildingId  String
  code        String
  level       String?
  type        ParkingSlotType
  isCovered   Boolean             @default(false)
  isActive    Boolean             @default(true)
  createdAt   DateTime            @default(now())
  org         Org                 @relation(fields: [orgId], references: [id], onDelete: Cascade)
  building    Building            @relation(fields: [buildingId], references: [id], onDelete: Cascade)
  allocations ParkingAllocation[]

  @@unique([buildingId, code])
  @@index([orgId, buildingId])
}

model ParkingAllocation {
  id            String      @id @default(cuid())
  orgId         String
  buildingId    String
  parkingSlotId String
  occupancyId   String?
  unitId        String?
  startDate     DateTime
  endDate       DateTime?
  createdAt     DateTime    @default(now())
  org           Org         @relation(fields: [orgId], references: [id], onDelete: Cascade)
  building      Building    @relation(fields: [buildingId], references: [id], onDelete: Cascade)
  parkingSlot   ParkingSlot @relation(fields: [parkingSlotId], references: [id], onDelete: Cascade)
  occupancy     Occupancy?  @relation(fields: [occupancyId], references: [id], onDelete: Cascade)
  unit          Unit?       @relation(fields: [unitId], references: [id], onDelete: Cascade)

  @@index([orgId, buildingId])
  @@index([orgId, occupancyId])
  @@index([orgId, unitId])
  @@index([orgId, createdAt])
  @@index([orgId, endDate])
  @@index([parkingSlotId])
}

model Vehicle {
  id          String    @id @default(cuid())
  orgId       String
  occupancyId String
  plateNumber String
  label       String?
  createdAt   DateTime  @default(now())
  org         Org       @relation(fields: [orgId], references: [id], onDelete: Cascade)
  occupancy   Occupancy @relation(fields: [occupancyId], references: [id], onDelete: Cascade)

  @@unique([orgId, plateNumber])
  @@index([orgId, occupancyId])
}

enum MaintenanceRequestStatus {
  OPEN
  ASSIGNED
  IN_PROGRESS
  COMPLETED
  CANCELED
}

enum MaintenanceRequestOwnerApprovalStatus {
  NOT_REQUIRED
  PENDING
  APPROVED
  REJECTED
}

enum MaintenanceRequestEstimateStatus {
  NOT_REQUESTED
  REQUESTED
  SUBMITTED
}

enum MaintenanceRequestOwnerApprovalDecisionSource {
  OWNER
  MANAGEMENT_OVERRIDE
  EMERGENCY_OVERRIDE
}

enum MaintenanceRequestOwnerApprovalAuditAction {
  REQUIRED
  REQUESTED
  RESENT
  APPROVED
  REJECTED
  OVERRIDDEN
}

enum MaintenanceRequestPriority {
  LOW
  NORMAL
  HIGH
}

enum MaintenanceRequestType {
  CLEANING
  ELECTRICAL
  MAINTENANCE
  PLUMBING_AC_HEATING
  OTHER
}

enum MaintenanceRequestEmergencySignal {
  ACTIVE_LEAK
  NO_POWER
  SAFETY_RISK
  NO_COOLING
}

model MaintenanceRequest {
  id                                String                                         @id @default(uuid())
  orgId                             String
  buildingId                        String
  unitId                            String?
  occupancyIdAtCreation             String?
  leaseIdAtCreation                 String?
  createdByUserId                   String
  title                             String
  description                       String?
  status                            MaintenanceRequestStatus                       @default(OPEN)
  type                              MaintenanceRequestType?
  priority                          MaintenanceRequestPriority?
  assignedToUserId                  String?
  serviceProviderId                 String?
  serviceProviderAssignedUserId     String?
  estimateStatus                    MaintenanceRequestEstimateStatus               @default(NOT_REQUESTED)
  estimateRequestedAt               DateTime?
  estimateRequestedByUserId         String?
  estimateDueAt                     DateTime?
  estimateReminderSentAt            DateTime?
  estimateSubmittedAt               DateTime?
  estimateSubmittedByUserId         String?
  ownerApprovalStatus               MaintenanceRequestOwnerApprovalStatus          @default(NOT_REQUIRED)
  ownerApprovalRequestedAt          DateTime?
  ownerApprovalRequestedByUserId    String?
  ownerApprovalDeadlineAt           DateTime?
  ownerApprovalDecidedAt            DateTime?
  ownerApprovalDecidedByOwnerUserId String?
  ownerApprovalReason               String?
  approvalRequiredReason            String?
  estimatedAmount                   Decimal?                                       @db.Decimal(12, 2)
  estimatedCurrency                 String?
  isEmergency                       Boolean                                        @default(false)
  emergencySignals                  MaintenanceRequestEmergencySignal[]            @default([])
  isLikeForLike                     Boolean?
  isUpgrade                         Boolean?
  isMajorReplacement                Boolean?
  isResponsibilityDisputed          Boolean?
  ownerApprovalDecisionSource       MaintenanceRequestOwnerApprovalDecisionSource?
  ownerApprovalOverrideReason       String?
  ownerApprovalOverriddenByUserId   String?
  assignedAt                        DateTime?
  completedAt                       DateTime?
  canceledAt                        DateTime?
  createdAt                         DateTime                                       @default(now())
  updatedAt                         DateTime                                       @updatedAt
  org                               Org                                            @relation(fields: [orgId], references: [id], onDelete: Cascade)
  building                          Building                                       @relation(fields: [buildingId], references: [id], onDelete: Cascade)
  unit                              Unit?                                          @relation(fields: [unitId], references: [id], onDelete: SetNull)
  occupancyAtCreation               Occupancy?                                     @relation("MaintenanceRequestCreationOccupancy", fields: [occupancyIdAtCreation], references: [id], onDelete: SetNull)
  leaseAtCreation                   Lease?                                         @relation("MaintenanceRequestCreationLease", fields: [leaseIdAtCreation], references: [id], onDelete: SetNull)
  createdByUser                     User                                           @relation("MaintenanceRequestCreator", fields: [createdByUserId], references: [id], onDelete: Cascade)
  assignedToUser                    User?                                          @relation("MaintenanceRequestAssignee", fields: [assignedToUserId], references: [id], onDelete: SetNull)
  serviceProvider                   ServiceProvider?                               @relation(fields: [serviceProviderId], references: [id], onDelete: SetNull)
  serviceProviderAssignedUser       User?                                          @relation("MaintenanceRequestServiceProviderAssignee", fields: [serviceProviderAssignedUserId], references: [id], onDelete: SetNull)
  estimateRequestedByUser           User?                                          @relation("MaintenanceRequestEstimateRequester", fields: [estimateRequestedByUserId], references: [id], onDelete: SetNull)
  estimateSubmittedByUser           User?                                          @relation("MaintenanceRequestEstimateSubmitter", fields: [estimateSubmittedByUserId], references: [id], onDelete: SetNull)
  ownerApprovalRequestedByUser      User?                                          @relation("MaintenanceRequestOwnerApprovalRequester", fields: [ownerApprovalRequestedByUserId], references: [id], onDelete: SetNull)
  ownerApprovalDecidedByOwnerUser   User?                                          @relation("MaintenanceRequestOwnerApprovalDecider", fields: [ownerApprovalDecidedByOwnerUserId], references: [id], onDelete: SetNull)
  ownerApprovalOverriddenByUser     User?                                          @relation("MaintenanceRequestOwnerApprovalOverrider", fields: [ownerApprovalOverriddenByUserId], references: [id], onDelete: SetNull)
  comments                          MaintenanceRequestComment[]
  commentReadStates                 MaintenanceRequestCommentReadState[]
  attachments                       MaintenanceRequestAttachment[]
  ownerApprovalAudits               MaintenanceRequestOwnerApprovalAudit[]
  ownerCommentReadStates            OwnerRequestCommentReadState[]

  @@index([orgId, buildingId])
  @@index([orgId, createdAt])
  @@index([orgId, completedAt])
  @@index([orgId, canceledAt])
  @@index([occupancyIdAtCreation])
  @@index([leaseIdAtCreation])
  @@index([createdByUserId])
  @@index([assignedToUserId])
  @@index([serviceProviderId])
  @@index([serviceProviderAssignedUserId])
  @@index([estimateStatus])
  @@index([estimateDueAt])
  @@index([estimateReminderSentAt])
  @@index([estimateRequestedByUserId])
  @@index([estimateSubmittedByUserId])
  @@index([status])
  @@index([ownerApprovalStatus])
}

model MaintenanceRequestComment {
  id            String                              @id @default(uuid())
  requestId     String
  orgId         String
  authorUserId  String
  authorOwnerId String?
  authorType    MaintenanceRequestCommentAuthorType
  visibility    MaintenanceRequestCommentVisibility @default(SHARED)
  message       String
  createdAt     DateTime                            @default(now())
  request       MaintenanceRequest                  @relation(fields: [requestId], references: [id], onDelete: Cascade)
  org           Org                                 @relation(fields: [orgId], references: [id], onDelete: Cascade)
  authorUser    User                                @relation(fields: [authorUserId], references: [id], onDelete: Cascade)
  authorOwner   Owner?                              @relation("MaintenanceRequestCommentOwner", fields: [authorOwnerId], references: [id], onDelete: SetNull)

  @@index([requestId])
  @@index([requestId, visibility, createdAt])
  @@index([authorUserId])
  @@index([authorOwnerId])
}

model OwnerRequestCommentReadState {
  id         String             @id @default(uuid())
  userId     String
  requestId  String
  lastReadAt DateTime
  createdAt  DateTime           @default(now())
  updatedAt  DateTime           @updatedAt
  user       User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  request    MaintenanceRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)

  @@unique([userId, requestId])
  @@index([userId, lastReadAt])
  @@index([requestId])
}

model MaintenanceRequestCommentReadState {
  id         String                             @id @default(uuid())
  userId     String
  requestId  String
  scope      MaintenanceRequestCommentReadScope
  lastReadAt DateTime
  createdAt  DateTime                           @default(now())
  updatedAt  DateTime                           @updatedAt
  user       User                               @relation(fields: [userId], references: [id], onDelete: Cascade)
  request    MaintenanceRequest                 @relation(fields: [requestId], references: [id], onDelete: Cascade)

  @@unique([userId, requestId, scope])
  @@index([userId, scope, lastReadAt])
  @@index([requestId, scope])
}

model MaintenanceRequestAttachment {
  id               String             @id @default(uuid())
  requestId        String
  orgId            String
  uploadedByUserId String
  fileName         String
  mimeType         String
  sizeBytes        Int
  url              String
  createdAt        DateTime           @default(now())
  request          MaintenanceRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  org              Org                @relation(fields: [orgId], references: [id], onDelete: Cascade)
  uploadedByUser   User               @relation(fields: [uploadedByUserId], references: [id], onDelete: Cascade)

  @@index([requestId])
}

model MaintenanceRequestOwnerApprovalAudit {
  id             String                                         @id @default(uuid())
  requestId      String
  orgId          String
  actorUserId    String?
  action         MaintenanceRequestOwnerApprovalAuditAction
  fromStatus     MaintenanceRequestOwnerApprovalStatus?
  toStatus       MaintenanceRequestOwnerApprovalStatus
  decisionSource MaintenanceRequestOwnerApprovalDecisionSource?
  reason         String?
  createdAt      DateTime                                       @default(now())
  request        MaintenanceRequest                             @relation(fields: [requestId], references: [id], onDelete: Cascade)
  org            Org                                            @relation(fields: [orgId], references: [id], onDelete: Cascade)
  actorUser      User?                                          @relation("MaintenanceRequestOwnerApprovalAuditActor", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([requestId, createdAt])
  @@index([orgId, createdAt])
}

enum MaintenanceRequestCommentAuthorType {
  OWNER
  TENANT
  STAFF
  SYSTEM
}

enum MaintenanceRequestCommentVisibility {
  SHARED
  INTERNAL
}

enum MaintenanceRequestCommentReadScope {
  BUILDING
  PROVIDER
}

enum NotificationType {
  REQUEST_CREATED
  REQUEST_ASSIGNED
  REQUEST_STATUS_CHANGED
  REQUEST_COMMENTED
  REQUEST_CANCELED
  ESTIMATE_REMINDER
  OWNER_APPROVAL_REQUESTED
  OWNER_APPROVAL_REMINDER
  OWNER_REQUEST_APPROVED
  OWNER_REQUEST_REJECTED
  OWNER_REQUEST_OVERRIDDEN
  OWNER_ACCESS_GRANTED
  OWNER_ACCESS_DISABLED
  MOVE_IN_REQUEST_CREATED
  MOVE_OUT_REQUEST_CREATED
  VISITOR_ARRIVED
  BROADCAST
  CONVERSATION_CREATED
  MESSAGE_CREATED
}

model Notification {
  id              String           @id @default(uuid())
  orgId           String
  recipientUserId String
  type            NotificationType
  title           String
  body            String?
  data            Json
  readAt          DateTime?
  dismissedAt     DateTime?
  createdAt       DateTime         @default(now())
  org             Org              @relation(fields: [orgId], references: [id], onDelete: Cascade)
  recipientUser   User             @relation("NotificationRecipient", fields: [recipientUserId], references: [id], onDelete: Cascade)

  @@index([recipientUserId, createdAt])
  @@index([orgId, recipientUserId])
  @@index([orgId, recipientUserId, readAt, createdAt])
  @@index([orgId, recipientUserId, dismissedAt, createdAt])
}

model Broadcast {
  id             String   @id @default(uuid())
  orgId          String
  senderUserId   String
  title          String
  body           String?
  buildingIds    String[]
  recipientCount Int      @default(0)
  metadata       Json?
  createdAt      DateTime @default(now())

  org        Org  @relation(fields: [orgId], references: [id], onDelete: Cascade)
  senderUser User @relation("BroadcastSender", fields: [senderUserId], references: [id], onDelete: Cascade)

  @@index([orgId, createdAt])
  @@index([senderUserId])
}

enum ConversationType {
  MANAGEMENT_INTERNAL
  MANAGEMENT_TENANT
  MANAGEMENT_OWNER
  OWNER_TENANT
}

enum ConversationCounterpartyGroup {
  STAFF
  TENANT
  OWNER
  MIXED
}

model Conversation {
  id                String                        @id @default(uuid())
  orgId             String
  buildingId        String?
  type              ConversationType
  counterpartyGroup ConversationCounterpartyGroup
  subject           String?
  createdAt         DateTime                      @default(now())
  updatedAt         DateTime                      @updatedAt

  org          Org                       @relation(fields: [orgId], references: [id], onDelete: Cascade)
  building     Building?                 @relation(fields: [buildingId], references: [id], onDelete: Cascade)
  participants ConversationParticipant[]
  messages     Message[]

  @@index([orgId, updatedAt])
  @@index([orgId, type, updatedAt])
  @@index([orgId, counterpartyGroup, updatedAt])
  @@index([buildingId])
}

model ConversationParticipant {
  id             String    @id @default(uuid())
  conversationId String
  userId         String
  lastReadAt     DateTime?
  createdAt      DateTime  @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([conversationId, userId])
  @@index([userId])
}

model Message {
  id             String   @id @default(uuid())
  conversationId String
  senderUserId   String
  content        String
  createdAt      DateTime @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  senderUser   User         @relation("MessageSender", fields: [senderUserId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
  @@index([senderUserId])
}

model RoleTemplate {
  id              String                   @id @default(uuid())
  orgId           String?
  key             String
  name            String
  description     String?
  isSystem        Boolean                  @default(true)
  scopeType       AccessScopeType          @default(ORG)
  createdAt       DateTime                 @default(now())
  updatedAt       DateTime                 @updatedAt
  org             Org?                     @relation(fields: [orgId], references: [id], onDelete: Cascade)
  rolePermissions RoleTemplatePermission[]
  assignments     UserAccessAssignment[]

  @@unique([orgId, key])
  @@index([orgId])
  @@index([orgId, scopeType])
  @@map("Role")
}

model Permission {
  id              String                   @id @default(uuid())
  key             String                   @unique
  name            String
  description     String?
  createdAt       DateTime                 @default(now())
  updatedAt       DateTime                 @updatedAt
  rolePermissions RoleTemplatePermission[]
  userPermissions UserPermission[]
}

model RoleTemplatePermission {
  roleTemplateId String       @map("roleId")
  permissionId   String
  createdAt      DateTime     @default(now())
  roleTemplate   RoleTemplate @relation(fields: [roleTemplateId], references: [id], onDelete: Cascade)
  permission     Permission   @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleTemplateId, permissionId])
  @@map("RolePermission")
}

model UserAccessAssignment {
  id             String          @id @default(uuid())
  userId         String
  roleTemplateId String
  scopeType      AccessScopeType
  scopeId        String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  roleTemplate   RoleTemplate    @relation(fields: [roleTemplateId], references: [id], onDelete: Cascade)
  buildingScope  Building?       @relation("BuildingScopedAccessAssignments", fields: [scopeId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([roleTemplateId])
  @@index([scopeType, scopeId])
  @@index([userId, scopeType, scopeId])
}

enum PermissionEffect {
  ALLOW
  DENY
}

model UserPermission {
  userId       String
  permissionId String
  effect       PermissionEffect
  createdAt    DateTime         @default(now())
  user         User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  permission   Permission       @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([userId, permissionId])
}

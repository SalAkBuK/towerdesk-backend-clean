  @@index([userId])
  @@index([preferredBuildingId])
}

model LeaseDocument {
  id        String            @id @default(uuid())
  leaseId   String
  orgId     String
  type      LeaseDocumentType
  fileName  String
  mimeType  String
  sizeBytes Int
  url       String
  createdAt DateTime          @default(now())
  lease     Lease             @relation(fields: [leaseId], references: [id], onDelete: Cascade)
  org       Org               @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([leaseId])
  @@index([orgId])
  @@index([leaseId, type])
}

model LeaseAccessCard {
  id         String           @id @default(uuid())
  leaseId    String
  cardNumber String
  status     AccessItemStatus @default(ISSUED)
  issuedAt   DateTime         @default(now())
  returnedAt DateTime?

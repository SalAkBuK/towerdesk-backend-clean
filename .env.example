APP_RUNTIME=api
NODE_ENV=development
PORT=3000
DATABASE_URL=postgresql://USER:PASSWORD@localhost:5432/towerdesk
JWT_ACCESS_SECRET=replace-me-with-a-long-random-local-secret
JWT_REFRESH_SECRET=replace-me-with-a-different-long-random-local-secret
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=604800

# PostgreSQL session options
PGOPTIONS=-c statement_timeout=8000 -c lock_timeout=3000 -c idle_in_transaction_session_timeout=30000
PRISMA_APPLY_SESSION_TIMEOUTS=false

# HTTP, throttling, logging, and Swagger
HTTP_BODY_LIMIT=1mb
HTTP_REQUEST_LOGGING_ENABLED=true
HTTP_SLOW_REQUEST_THRESHOLD_MS=1000
HTTP_SERVER_TIMEOUT_MS=30000
HTTP_HEADERS_TIMEOUT_MS=35000
HTTP_KEEP_ALIVE_TIMEOUT_MS=5000
THROTTLE_TTL=60
THROTTLE_LIMIT=300
THROTTLE_AUTH_TTL=60
THROTTLE_AUTH_LIMIT=10
DEFAULT_PAGE_SIZE=50
MAX_PAGE_SIZE=100
REQUEST_METRICS_ENABLED=false
REQUEST_METRICS_INTERVAL_MS=60000
REQUEST_METRICS_SAMPLE_SIZE=300
SWAGGER_ENABLED=true

# Maintenance reminders
MAINTENANCE_ESTIMATE_REMINDER_ENABLED=true
MAINTENANCE_ESTIMATE_REMINDER_INTERVAL_MS=900000
MAINTENANCE_ESTIMATE_DEFAULT_TTL_HOURS=24

# Realtime notifications
WS_CORS_ORIGINS=http://localhost:3000,http://localhost:3001
WS_LOG_CONNECTIONS=true

# Push notifications
PUSH_PROVIDER=noop
PUSH_EXPO_ACCESS_TOKEN=
PUSH_LOG_DELIVERIES=true
PUSH_RECEIPTS_ENABLED=false
PUSH_RECEIPT_POLL_INTERVAL_MS=300000
PUSH_RECEIPT_LOOKUP_DELAY_MS=900000

# Email
EMAIL_PROVIDER=noop
EMAIL_FROM=no-reply@example.test
EMAIL_SMTP_HOST=
EMAIL_SMTP_PORT=587
EMAIL_SMTP_SECURE=false
EMAIL_SMTP_USER=
EMAIL_SMTP_PASS=
AUTH_PASSWORD_RESET_TTL_MINUTES=30
RESIDENT_INVITE_RESEND_COOLDOWN_SECONDS=60
AUTH_PASSWORD_RESET_URL_TEMPLATE=http://localhost:3000/reset-password?token={{token}}&mode={{mode}}
MOBILE_APP_IOS_URL=
MOBILE_APP_ANDROID_URL=
MOBILE_APP_DEEP_LINK_URL=
AUTH_PUBLIC_REGISTER_ENABLED=true

# Owner identity and resolution
OWNER_IDENTIFIER_ENCRYPTION_KEY=
OWNER_IDENTIFIER_HMAC_KEY=
OWNER_RESOLUTION_TOKEN_SECRET=
OWNER_RESOLUTION_TOKEN_TTL_SECONDS=600

# Queue / workers
QUEUE_ENABLED=false
QUEUE_HOST=localhost
QUEUE_PORT=6379
QUEUE_PASSWORD=
DELIVERY_TASK_RETENTION_ENABLED=false
DELIVERY_TASK_RETENTION_INTERVAL_MS=3600000
DELIVERY_TASK_RETENTION_DAYS=30

# S3-compatible storage
STORAGE_ENDPOINT=
STORAGE_REGION=auto
STORAGE_BUCKET=
STORAGE_PUBLIC_BASE_URL=
STORAGE_ACCESS_KEY_ID=
STORAGE_SECRET_ACCESS_KEY=

# Platform administration
PLATFORM_API_KEY=replace-me-with-a-long-random-local-platform-key
PLATFORM_SUPERADMIN_EMAIL=platform-admin@example.test
PLATFORM_SUPERADMIN_PASSWORD=replace-me-with-a-local-only-password
